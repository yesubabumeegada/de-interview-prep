---
/**
 * Card.astro — Premium card with spring lift, gradient glow, and shine effect.
 *
 * Props:
 *   - href: Optional link (makes card clickable)
 *   - class: Additional CSS classes
 */
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'card-premium block rounded-xl p-4 focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2',
    href && 'no-underline cursor-pointer',
    className,
  ]}
>
  <slot />
</Tag>

<style is:global>
  .card-premium {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-surface-tertiary);
    box-shadow: var(--shadow-card);
    transition:
      transform       220ms cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow      220ms ease,
      border-color    200ms ease;
  }

  .card-premium:hover {
    transform: translateY(-4px) scale(1.005);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-primary-light);
  }

  .dark .card-premium:hover {
    border-color: var(--color-primary-dark);
  }

  .card-premium:active {
    transform: translateY(-1px) scale(0.998);
    transition-duration: 80ms;
  }

  /* Gradient glow layer */
  .card-premium::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent), var(--color-primary-light));
    opacity: 0;
    z-index: -1;
    transition: opacity 300ms ease;
  }

  .card-premium:hover::before { opacity: 0.10; }
  .dark .card-premium:hover::before { opacity: 0.18; }

  /* Shine sweep on hover */
  .card-premium::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      transparent 30%,
      rgba(255, 255, 255, 0.06) 50%,
      transparent 70%
    );
    transform: translateX(-100%);
    transition: transform 500ms ease;
    pointer-events: none;
    border-radius: inherit;
  }

  .card-premium:hover::after {
    transform: translateX(100%);
  }
</style>
