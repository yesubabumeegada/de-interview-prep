{icon ? (
  <svg
    role="img"
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill={icon.hex}
    xmlns="http://www.w3.org/2000/svg"
    class={cls}
    aria-hidden="true"
  >
    <path d={icon.path} />
  </svg>
) : stroke ? (
  <svg
    viewBox="0 0 24 24"
    width={size}
    height={size}
    fill="none"
    stroke={stroke.color}
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    xmlns="http://www.w3.org/2000/svg"
    class={cls}
    aria-hidden="true"
  >
    {stroke.paths.map(d => <path d={d} />)}
  </svg>
) : (
  <span class={cls} style={`font-size:${size * 0.9}px;`} aria-hidden="true">📖</span>
)}
