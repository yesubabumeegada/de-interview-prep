---
/**
 * CodeBlock Component
 *
 * Renders code snippets with syntax highlighting, line numbers, language badge,
 * copy-to-clipboard functionality, and scrollable containers for long snippets.
 *
 * Requirements: 2.2, 2.3, 2.6, 7.2, 7.4, 7.5
 */
import type { CodeBlockProps } from './CodeBlock.types';

interface Props extends CodeBlockProps {}

const { code, language, showLineNumbers = true, maxHeight } = Astro.props;

// Compute line numbers starting at 1
const lines = code.split('\n');
const lineCount = lines.length;

// Determine if scroll should be applied (> 30 lines → max-height 500px)
const effectiveMaxHeight = lineCount > 30 ? (maxHeight ?? 500) : undefined;
const shouldScroll = lineCount > 30;

// Determine if we have a valid language for highlighting
const hasLanguage = language && language.trim().length > 0;
const displayLanguage = hasLanguage ? language.trim().toLowerCase() : '';

// Generate a unique ID for this code block (for copy button)
const blockId = `code-block-${Math.random().toString(36).substring(2, 9)}`;
---

<div class="code-block-wrapper relative rounded-md overflow-hidden shadow-card bg-surface-tertiary dark:bg-surface-secondary border border-content-tertiary/20">
  {/* Header bar with language badge and copy button */}
  <div class="code-block-header flex items-center justify-between px-2 py-0.5 bg-surface-secondary dark:bg-surface-tertiary border-b border-content-tertiary/20">
    {hasLanguage ? (
      <span class="code-block-language-label text-caption font-mono font-medium text-primary uppercase tracking-wide px-0.5 py-[2px] rounded-sm bg-primary/10 dark:bg-primary/20">
        {displayLanguage}
      </span>
    ) : (
      <span class="code-block-language-label text-caption font-mono text-content-tertiary">
        plain text
      </span>
    )}
    <button
      class="code-block-copy-btn inline-flex items-center gap-[4px] px-1 py-[4px] text-body-sm rounded-sm text-content-secondary hover:text-primary hover:bg-primary/10 transition-colors duration-150 min-w-touch min-h-touch cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
      data-code={code}
      data-block-id={blockId}
      aria-label="Copy code to clipboard"
      type="button"
    >
      <svg class="copy-icon w-[16px] h-[16px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
      </svg>
      <svg class="check-icon w-[16px] h-[16px] hidden text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      <span class="copy-text text-caption">Copy</span>
    </button>
  </div>

  {/* Code content area */}
  <div
    class:list={[
      'code-block-content custom-scrollbar',
      shouldScroll && 'overflow-y-auto',
    ]}
    style={effectiveMaxHeight ? `max-height: ${effectiveMaxHeight}px;` : undefined}
  >
    {hasLanguage ? (
      <pre class={`language-${displayLanguage} !m-0 !rounded-none`}><code class={`language-${displayLanguage} text-body-sm font-mono`}>
        <table class="code-table w-full border-collapse">
          <tbody>
            {lines.map((line, index) => (
              <tr class="code-line hover:bg-primary/5 transition-colors duration-150">
                {showLineNumbers && (
                  <td class="code-line-number select-none text-right pr-1 pl-1 text-content-tertiary text-caption font-mono w-[3em] border-r border-content-tertiary/20 align-top">
                    {index + 1}
                  </td>
                )}
                <td class="code-line-content pl-1 pr-2 whitespace-pre font-mono text-body-sm text-content dark:text-content">
                  {line || ' '}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </code></pre>
    ) : (
      <pre class="!m-0 !rounded-none"><code class="text-body-sm font-mono text-content">
        <table class="code-table w-full border-collapse">
          <tbody>
            {lines.map((line, index) => (
              <tr class="code-line hover:bg-primary/5 transition-colors duration-150">
                {showLineNumbers && (
                  <td class="code-line-number select-none text-right pr-1 pl-1 text-content-tertiary text-caption font-mono w-[3em] border-r border-content-tertiary/20 align-top">
                    {index + 1}
                  </td>
                )}
                <td class="code-line-content pl-1 pr-2 whitespace-pre font-mono text-body-sm text-content dark:text-content">
                  {line || ' '}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </code></pre>
    )}
  </div>
</div>

<script>
  /**
   * Copy-to-clipboard functionality for CodeBlock components.
   * Shows visual confirmation (checkmark icon) for 1-3 seconds after copy.
   */
  function initCopyButtons() {
    const copyButtons = document.querySelectorAll('.code-block-copy-btn');

    copyButtons.forEach((button) => {
      button.addEventListener('click', async () => {
        const code = button.getAttribute('data-code');
        if (!code) return;

        try {
          await navigator.clipboard.writeText(code);

          // Show success state
          const copyIcon = button.querySelector('.copy-icon') as HTMLElement;
          const checkIcon = button.querySelector('.check-icon') as HTMLElement;
          const copyText = button.querySelector('.copy-text') as HTMLElement;

          if (copyIcon && checkIcon && copyText) {
            copyIcon.classList.add('hidden');
            checkIcon.classList.remove('hidden');
            copyText.textContent = 'Copied!';

            // Revert after 2 seconds (within the 1-3 second requirement)
            setTimeout(() => {
              copyIcon.classList.remove('hidden');
              checkIcon.classList.add('hidden');
              copyText.textContent = 'Copy';
            }, 2000);
          }
        } catch (err) {
          // Fallback for browsers that don't support clipboard API
          const textarea = document.createElement('textarea');
          textarea.value = code;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();

          try {
            document.execCommand('copy');
            const copyIcon = button.querySelector('.copy-icon') as HTMLElement;
            const checkIcon = button.querySelector('.check-icon') as HTMLElement;
            const copyText = button.querySelector('.copy-text') as HTMLElement;

            if (copyIcon && checkIcon && copyText) {
              copyIcon.classList.add('hidden');
              checkIcon.classList.remove('hidden');
              copyText.textContent = 'Copied!';

              setTimeout(() => {
                copyIcon.classList.remove('hidden');
                checkIcon.classList.add('hidden');
                copyText.textContent = 'Copy';
              }, 2000);
            }
          } catch (e) {
            console.error('Failed to copy code:', e);
          } finally {
            document.body.removeChild(textarea);
          }
        }
      });
    });
  }

  // Initialize on DOM ready
  document.addEventListener('DOMContentLoaded', initCopyButtons);
  // Also init immediately in case DOM is already loaded (SPA navigation)
  if (document.readyState !== 'loading') {
    initCopyButtons();
  }
</script>

<style>
  /* Code block styling */
  .code-block-wrapper {
    margin: 12px 0;
  }

  .code-table {
    border-spacing: 0;
  }

  .code-line-number {
    user-select: none;
    -webkit-user-select: none;
    vertical-align: top;
    position: sticky;
    left: 0;
    background: inherit;
  }

  .code-line-content {
    white-space: pre;
    word-break: break-all;
    overflow-wrap: break-word;
  }

  /* Ensure pre/code have proper backgrounds */
  pre {
    background-color: var(--color-surface-tertiary);
    padding: 12px 0;
  }

  :global(.dark) pre {
    background-color: var(--color-surface-secondary);
  }

  /* Override any prism theme backgrounds to match our design */
  pre[class*='language-'] {
    background-color: var(--color-surface-tertiary) !important;
    margin: 0 !important;
    border-radius: 0 !important;
    padding: 12px 0 !important;
  }

  :global(.dark) pre[class*='language-'] {
    background-color: var(--color-surface-secondary) !important;
  }

  /* Custom scrollbar for code blocks */
  .code-block-content::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .code-block-content::-webkit-scrollbar-track {
    background: var(--color-surface-secondary);
  }

  .code-block-content::-webkit-scrollbar-thumb {
    background: var(--color-content-tertiary);
    border-radius: 4px;
  }

  .code-block-content::-webkit-scrollbar-thumb:hover {
    background: var(--color-content-secondary);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .code-line {
      transition: none !important;
    }
  }
</style>
