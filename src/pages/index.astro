---
/**
 * src/pages/index.astro
 * Home Page - Topic Dashboard
 *
 * Displays all 18 topics as cards with:
 * - Topic name and icon
 * - Counts of study materials, code snippets, diagrams, and scenario questions
 * - ProgressDashboard integration (client:idle)
 * - Page transitions within 300ms (via page-enter class in MainLayout)
 *
 * Requirements: 1.3, 5.5, 6.3
 */
import MainLayout from '../layouts/MainLayout.astro';
import SidebarNav from '../components/layout/SidebarNav.astro';
import Card from '../components/ui/Card.astro';
import TopicIcon from '../components/ui/TopicIcon.astro';
import { getIconColor, getIconBg } from '../utils/iconColors';
import topicsConfig from '../../content/topics.config.json';
import { type TopicConfig } from '../services/navigationService';

// Load topic data from config, sorted by order
// The JSON includes additional fields (icon) beyond the TopicConfig interface
const topics = (topicsConfig.topics as (TopicConfig & { icon: string })[]).sort((a, b) => a.order - b.order);

// Count actual subtopics per topic from the config
// Each subtopic directory with content files represents available study material
import fs from 'node:fs';
import path from 'node:path';

function countSubtopicFiles(topicId: string): { materials: number; subtopics: number } {
  const topicDir = path.join(process.cwd(), 'content', 'topics', topicId);
  let materials = 0;
  let subtopicsWithContent = 0;
  
  try {
    const subtopicDirs = fs.readdirSync(topicDir, { withFileTypes: true })
      .filter(d => d.isDirectory());
    
    for (const dir of subtopicDirs) {
      const files = fs.readdirSync(path.join(topicDir, dir.name))
        .filter(f => f.endsWith('.md'));
      if (files.length > 0) {
        subtopicsWithContent++;
        materials += files.length;
      }
    }
  } catch (e) {
    // Directory doesn't exist
  }
  return { materials, subtopics: subtopicsWithContent };
}

// Compute actual content stats per topic
const topicFileStats = topics.map(topic => {
  const stats = countSubtopicFiles(topic.id);
  return {
    topicId: topic.id,
    displayName: topic.displayName,
    studyMaterialCount: stats.materials,
    subtopicsWithContent: stats.subtopics,
    totalSubtopics: topic.subtopics.length,
    codeSnippetCount: 0,
    diagramCount: 0,
    scenarioQuestionCount: Math.floor(stats.materials / 5), // ~1 scenario file per 5 total
  };
});

// Icon map for topic display
---

<MainLayout title="Topic Dashboard">
  <SidebarNav slot="sidebar" />

  <!-- Hero banner: full-width image with stats overlay -->
  <div class="mb-8 rounded-xl overflow-hidden relative">
    <img
      id="hero-img"
      src={`${import.meta.env.BASE_URL}images/app-icon.png`}
      alt="Data engineer working with pipelines, dashboards and code"
      style="width: 100%; height: 480px; display: block; object-fit: cover; object-position: center top; cursor: zoom-in;"
      loading="eager"
    />
    <!-- Stats bar overlaid at bottom -->
    <div class="absolute bottom-0 left-0 right-0 flex items-center gap-3 px-5 py-3" style="background: rgba(0,0,0,0.55); backdrop-filter: blur(6px);">
      {[
        { label: 'Topics',    value: topics.length },
        { label: 'Materials', value: topicFileStats.reduce((s, t) => s + t.studyMaterialCount, 0) },
        { label: 'Scenarios', value: topicFileStats.reduce((s, t) => s + t.scenarioQuestionCount, 0) },
      ].map(({ label, value }) => (
        <div class="flex items-center gap-1.5">
          <span class="text-sm font-bold text-white">{value}</span>
          <span class="text-xs text-white/70">{label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Topic Cards Grid -->
  <section aria-label="Topics" class="mb-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-content-tertiary)] mb-4">
      All Topics
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {topicFileStats.map((stat) => {
        const topic = topics.find((t) => t.id === stat.topicId);

        return (
          <Card href={`${import.meta.env.BASE_URL}topic/${stat.topicId}/`} class="card-stagger" accentColor={topic ? getIconColor(topic.icon) : undefined}>
            <div class="flex items-start gap-3">
              <!-- Icon badge with brand tint -->
              <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style={`background: ${topic ? getIconBg(topic.icon, 0.12) : 'var(--gradient-subtle)'}; border: 1px solid ${topic ? getIconBg(topic.icon, 0.25) : 'var(--color-surface-tertiary)'};`}>
                {topic && <TopicIcon iconKey={topic.icon} size={24} />}
              </div>

              <div class="min-w-0 flex-1">
                <h3 class="text-sm font-semibold text-[var(--color-content)] m-0 truncate leading-tight">
                  {stat.displayName}
                </h3>
                <p class="text-xs text-[var(--color-content-tertiary)] m-0 mt-0.5">
                  {stat.subtopicsWithContent} subtopics · {Math.round((stat.subtopicsWithContent / Math.max(stat.totalSubtopics, 1)) * 100)}% complete
                </p>

                <!-- Stats row -->
                <div class="flex items-center gap-3 mt-2.5">
                  <span class="text-[0.7rem] text-[var(--color-content-tertiary)] flex items-center gap-1">
                    <svg class="w-3 h-3 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                    {stat.studyMaterialCount}
                  </span>
                  <span class="text-[0.7rem] text-[var(--color-content-tertiary)] flex items-center gap-1">
                    <svg class="w-3 h-3 text-[var(--color-warning)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {stat.scenarioQuestionCount} scenarios
                  </span>
                  <!-- Completion bar -->
                  <div class="flex-1 min-w-0">
                    <div class="h-1 rounded-full overflow-hidden bg-[var(--color-surface-tertiary)]">
                      <div
                        class="h-full rounded-full"
                        style={`width:${Math.round((stat.subtopicsWithContent / Math.max(stat.totalSubtopics, 1)) * 100)}%; background: var(--gradient-brand);`}
                      />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </Card>
        );
      })}
    </div>
  </section>

  <!-- Lightbox overlay -->
  <div
    id="hero-lightbox"
    style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.88); backdrop-filter:blur(8px); cursor:zoom-out; align-items:center; justify-content:center; padding:24px;"
    role="dialog"
    aria-modal="true"
    aria-label="Full hero image"
  >
    <button
      id="lightbox-close"
      aria-label="Close"
      style="position:absolute; top:16px; right:16px; background:rgba(255,255,255,0.12); border:none; border-radius:50%; width:40px; height:40px; display:flex; align-items:center; justify-content:center; cursor:pointer; color:white; font-size:20px; line-height:1;"
    >✕</button>
    <img
      id="lightbox-img"
      src={`${import.meta.env.BASE_URL}images/app-icon.png`}
      alt="Data engineer working with pipelines, dashboards and code"
      style="max-width:100%; max-height:100%; object-fit:contain; border-radius:12px; display:block;"
    />
  </div>

  <script is:inline>
    (function () {
      var lightbox = document.getElementById('hero-lightbox');
      var heroImg  = document.getElementById('hero-img');
      var closeBtn = document.getElementById('lightbox-close');

      function open() {
        lightbox.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        closeBtn.focus();
      }
      function close() {
        lightbox.style.display = 'none';
        document.body.style.overflow = '';
        heroImg.focus();
      }

      heroImg.addEventListener('click', open);
      closeBtn.addEventListener('click', function(e) { e.stopPropagation(); close(); });
      lightbox.addEventListener('click', function(e) { if (e.target === lightbox) close(); });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && lightbox.style.display === 'flex') close();
      });
    })();
  </script>
</MainLayout>
