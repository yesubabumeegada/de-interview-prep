---
/**
 * src/pages/topic/[topicId]/[subtopicId].astro
 * Subtopic Content Page - Renders subtopic content with layered structure.
 *
 * Uses Astro's getStaticPaths() to generate pages for all topic/subtopic combinations.
 * Displays:
 * - Breadcrumb navigation
 * - Layered content (Fundamentals → Intermediate → Senior-Level → Real-World)
 *   via LayerCollapse component
 * - Difficulty filter for scenario questions
 * - "Content not yet available" message for empty subtopics
 * - "Mark as Reviewed" control via ProgressDashboard
 *
 * Requirements: 1.2, 1.5, 3.4, 5.5, 6.1, 13.1
 */
import MainLayout from '../../../layouts/MainLayout.astro';
import SidebarNav from '../../../components/layout/SidebarNav.astro';
import Breadcrumbs from '../../../components/layout/Breadcrumbs.astro';
import ContentRenderer from '../../../components/content/ContentRenderer.astro';
import LayerCollapse from '../../../components/interactive/LayerCollapse.tsx';
import topicsConfig from '../../../../content/topics.config.json';
import fs from 'node:fs';
import path from 'node:path';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkGfm from 'remark-gfm';
import remarkMermaid from '../../../plugins/remarkMermaid.ts';
import remarkRehype from 'remark-rehype';
import rehypeStringify from 'rehype-stringify';

export function getStaticPaths() {
  const paths: { params: { topicId: string; subtopicId: string }; props: any }[] = [];

  for (const topic of topicsConfig.topics) {
    for (const subtopic of topic.subtopics) {
      paths.push({
        params: { topicId: topic.id, subtopicId: subtopic.id },
        props: {
          topic: { id: topic.id, displayName: topic.displayName, icon: topic.icon },
          subtopic: { id: subtopic.id, displayName: subtopic.displayName },
        },
      });
    }
  }

  return paths;
}

interface Props {
  topic: { id: string; displayName: string; icon: string };
  subtopic: { id: string; displayName: string };
}

const { topicId, subtopicId } = Astro.params;
const { topic, subtopic } = Astro.props;

/**
 * Attempt to load markdown content for each layer.
 * Content files are expected at: content/topics/{topicId}/{subtopicId}/{layer}.md
 * If no content files exist, the page shows a "content not yet available" message.
 */
const layerFiles = [
  { id: 'fundamentals' as const, file: 'fundamentals.md', label: 'Fundamentals' },
  { id: 'intermediate' as const, file: 'intermediate.md', label: 'Intermediate Concepts' },
  { id: 'senior-deep-dive' as const, file: 'senior-deep-dive.md', label: 'Senior-Level Deep Dive' },
  { id: 'real-world' as const, file: 'real-world.md', label: 'Real-World Production Examples' },
];

// Use process.cwd() which points to the project root when running from the project directory
const contentDir = path.join(process.cwd(), 'content', 'topics', topicId!, subtopicId!);
console.log('[subtopic] Looking for content at:', contentDir, 'exists:', fs.existsSync(contentDir));
let layerContents: { id: string; content: string }[] = [];
let hasContent = false;

// Markdown-to-HTML processor using unified/remark/rehype
const markdownProcessor = unified()
  .use(remarkParse)
  .use(remarkGfm)
  .use(remarkMermaid)
  .use(remarkRehype, { allowDangerousHtml: true })
  .use(rehypeStringify, { allowDangerousHtml: true });

async function processMarkdown(raw: string): Promise<string> {
  const result = await markdownProcessor.process(raw);
  return String(result);
}

try {
  if (fs.existsSync(contentDir)) {
    for (const layer of layerFiles) {
      const filePath = path.join(contentDir, layer.file);
      if (fs.existsSync(filePath)) {
        const raw = fs.readFileSync(filePath, 'utf-8');
        // Strip front-matter (content between --- delimiters at the start)
        const markdownContent = raw.replace(/^---[\s\S]*?---\s*/, '').trim();
        if (markdownContent) {
          const htmlContent = await processMarkdown(markdownContent);
          layerContents.push({ id: layer.id, content: htmlContent });
          hasContent = true;
        }
      }
    }
  }
} catch (e) {
  // Content directory doesn't exist or read failed - show empty state
}

// Check for scenario questions file
const scenariosPath = path.join(contentDir, 'scenarios.md');
let scenariosContent = '';
let hasScenarios = false;
try {
  if (fs.existsSync(scenariosPath)) {
    const raw = fs.readFileSync(scenariosPath, 'utf-8');
    const markdownScenarios = raw.replace(/^---[\s\S]*?---\s*/, '').trim();
    if (markdownScenarios) {
      scenariosContent = await processMarkdown(markdownScenarios);
      hasScenarios = true;
    }
  }
} catch (e) {
  // No scenarios file
}
---

<MainLayout title={`${subtopic.displayName} - ${topic.displayName}`}>
  <SidebarNav slot="sidebar" activeTopic={topicId} activeSubtopic={subtopicId} />

  <!-- Breadcrumb navigation -->
  <Breadcrumbs
    topicId={topicId}
    topicDisplayName={topic.displayName}
    subtopicId={subtopicId}
    subtopicDisplayName={subtopic.displayName}
  />

  <!-- Subtopic Header -->
  <header class="mb-[24px]">
    <h1 class="text-heading-1 text-[var(--color-content)] m-0">
      {subtopic.displayName}
    </h1>
    <p class="text-body text-[var(--color-content-secondary)] mt-[8px] m-0">
      {topic.displayName} &rsaquo; {subtopic.displayName}
    </p>
  </header>

  {/* Content not yet available message (Requirement 1.5) */}
  {!hasContent && !hasScenarios && (
    <div
      class="rounded-lg border border-[var(--color-surface-tertiary)] bg-[var(--color-surface-secondary)] p-[32px] text-center"
      role="status"
      data-testid="empty-subtopic-message"
    >
      <svg
        class="w-[48px] h-[48px] mx-auto mb-[16px] text-[var(--color-content-tertiary)]"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
        />
      </svg>
      <h2 class="text-heading-4 text-[var(--color-content)] mb-[8px]">
        Content Not Yet Available
      </h2>
      <p class="text-body text-[var(--color-content-secondary)] m-0">
        Study materials for {subtopic.displayName} in {topic.displayName} are being prepared. Check back soon!
      </p>
    </div>
  )}

  {/* Layered content structure (Requirement 13.1) */}
  {hasContent && (
    <section aria-label="Study Materials" class="mb-[32px]">
      <h2 class="text-heading-3 text-[var(--color-content)] mb-[16px]">
        Study Materials
      </h2>
      <LayerCollapse
        client:load
        layers={layerContents.map((layer) => ({
          id: layer.id as any,
          content: layer.content,
        }))}
      />
    </section>
  )}

  {/* Scenario Questions with Difficulty Filter (Requirement 3.4) */}
  {hasScenarios && (
    <section aria-label="Scenario Questions" class="mb-[32px]">
      <h2 class="text-heading-3 text-[var(--color-content)] mb-[16px]">
        Scenario Questions
      </h2>

      <!-- Difficulty Filter -->
      <div class="mb-[16px]" data-testid="difficulty-filter">
        <fieldset class="flex flex-wrap items-center gap-[8px]">
          <legend class="text-body-sm font-medium text-[var(--color-content-secondary)] mr-[8px]">
            Filter by difficulty:
          </legend>
          <label class="inline-flex items-center gap-[6px] cursor-pointer min-h-[44px] px-[12px] py-[6px] rounded-md border border-[var(--color-surface-tertiary)] hover:border-[var(--color-primary)]/50 transition-colors duration-150 has-[:checked]:bg-[var(--color-primary)]/10 has-[:checked]:border-[var(--color-primary)]">
            <input
              type="checkbox"
              name="difficulty"
              value="all"
              checked
              class="sr-only peer"
              data-filter="all"
            />
            <span class="text-body-sm text-[var(--color-content)] peer-checked:text-[var(--color-primary)] peer-checked:font-medium">
              All
            </span>
          </label>
          <label class="inline-flex items-center gap-[6px] cursor-pointer min-h-[44px] px-[12px] py-[6px] rounded-md border border-[var(--color-surface-tertiary)] hover:border-[var(--color-primary)]/50 transition-colors duration-150 has-[:checked]:bg-[var(--color-primary)]/10 has-[:checked]:border-[var(--color-primary)]">
            <input
              type="checkbox"
              name="difficulty"
              value="junior"
              class="sr-only peer"
              data-filter="junior"
            />
            <span class="text-body-sm text-[var(--color-content)] peer-checked:text-[var(--color-primary)] peer-checked:font-medium">
              Junior
            </span>
          </label>
          <label class="inline-flex items-center gap-[6px] cursor-pointer min-h-[44px] px-[12px] py-[6px] rounded-md border border-[var(--color-surface-tertiary)] hover:border-[var(--color-primary)]/50 transition-colors duration-150 has-[:checked]:bg-[var(--color-primary)]/10 has-[:checked]:border-[var(--color-primary)]">
            <input
              type="checkbox"
              name="difficulty"
              value="mid-level"
              class="sr-only peer"
              data-filter="mid-level"
            />
            <span class="text-body-sm text-[var(--color-content)] peer-checked:text-[var(--color-primary)] peer-checked:font-medium">
              Mid-Level
            </span>
          </label>
          <label class="inline-flex items-center gap-[6px] cursor-pointer min-h-[44px] px-[12px] py-[6px] rounded-md border border-[var(--color-surface-tertiary)] hover:border-[var(--color-primary)]/50 transition-colors duration-150 has-[:checked]:bg-[var(--color-primary)]/10 has-[:checked]:border-[var(--color-primary)]">
            <input
              type="checkbox"
              name="difficulty"
              value="senior"
              class="sr-only peer"
              data-filter="senior"
            />
            <span class="text-body-sm text-[var(--color-content)] peer-checked:text-[var(--color-primary)] peer-checked:font-medium">
              Senior
            </span>
          </label>
        </fieldset>
      </div>

      <!-- Rendered scenario content -->
      <div data-testid="scenarios-content" class="scenario-questions-container">
        <ContentRenderer content={scenariosContent} />
      </div>
    </section>
  )}
</MainLayout>

<script>
  /**
   * Client-side Mermaid diagram rendering.
   * Handles both:
   * 1. <pre class="mermaid"> from the remarkMermaid plugin
   * 2. Raw mermaid code blocks that passed through without the plugin
   */
  import DOMPurify from 'dompurify';

  // Mermaid is ~580KB minified — load it on demand, only when the page
  // actually contains a diagram. The loader initializes mermaid right after
  // import, so callers never see an uninitialised instance.
  let mermaidPromise: Promise<typeof import('mermaid').default> | null = null;
  function loadMermaid() {
    if (!mermaidPromise) {
      mermaidPromise = import('mermaid').then((m) => {
        m.default.initialize({
          startOnLoad: false,
          securityLevel: 'loose' as const,
          theme: 'base' as const,
        });
        return m.default;
      });
    }
    return mermaidPromise;
  }

  // SVG_ALLOW: DOMPurify config for mermaid-rendered SVGs.
  // mermaid with htmlLabels:true embeds HTML inside <foreignObject>, so we
  // must allow those HTML elements here or the node labels are stripped.
  const SVG_ALLOW = {
    ADD_TAGS: [
      // Core SVG
      'svg','g','defs','use','symbol','title','desc',
      'path','rect','circle','ellipse','line','polyline','polygon',
      'text','tspan','textPath',
      'marker','clipPath','pattern','linearGradient','radialGradient','stop',
      'image','foreignObject',
      // HTML inside foreignObject (mermaid htmlLabels:true)
      'div','span','p','br','label','b','i','strong','em','code','pre',
    ],
    ADD_ATTR: [
      // SVG attributes
      'viewBox','xmlns','xmlns:xlink','xlink:href','preserveAspectRatio',
      'style','class','id',
      'fill','fill-opacity','fill-rule',
      'stroke','stroke-width','stroke-dasharray','stroke-linecap','stroke-linejoin','stroke-opacity',
      'opacity',
      'd','cx','cy','r','rx','ry',
      'x','y','x1','y1','x2','y2','width','height',
      'transform','transform-origin',
      'text-anchor','dominant-baseline','alignment-baseline',
      'font-size','font-family','font-weight','font-style',
      'marker-end','marker-start','marker-mid',
      'refX','refY','markerWidth','markerHeight','orient',
      'clip-path','clip-rule',
      'points',
      'href',
      // Gradient
      'offset','stop-color','stop-opacity',
      'gradientUnits','gradientTransform',
      // Pattern
      'patternUnits','patternTransform',
      // foreignObject / HTML
      'color','background','border','padding','margin',
      'display','overflow','white-space','word-break',
    ],
    FORCE_BODY: false,
    RETURN_DOM: false,
  };

  /**
   * Build a mermaid config that matches the app's CSS design tokens.
   * Mirrors the same function in MermaidDiagram.astro so both rendering
   * paths produce identical themes. Uses 'base' theme + themeVariables
   * for full control, and securityLevel 'loose' for HTML labels.
   */
  function getMermaidConfig() {
    const isDark = document.documentElement.classList.contains('dark');

    const light = {
      primaryColor: '#ede9fe',
      primaryTextColor: '#3730a3',
      primaryBorderColor: '#4f46e5',
      lineColor: '#6366f1',
      secondaryColor: '#f0fdf4',
      secondaryTextColor: '#166534',
      secondaryBorderColor: '#16a34a',
      tertiaryColor: '#fef3c7',
      tertiaryTextColor: '#92400e',
      tertiaryBorderColor: '#d97706',
      background: '#ffffff',
      mainBkg: '#ede9fe',
      nodeBorder: '#4f46e5',
      clusterBkg: '#f8fafc',
      clusterBorder: '#cbd5e1',
      titleColor: '#1e293b',
      edgeLabelBackground: '#f8fafc',
      fontFamily: 'Inter, system-ui, -apple-system, sans-serif',
      fontSize: '14px',
    };

    const dark = {
      primaryColor: '#312e81',
      primaryTextColor: '#c7d2fe',
      primaryBorderColor: '#818cf8',
      lineColor: '#818cf8',
      secondaryColor: '#052e16',
      secondaryTextColor: '#86efac',
      secondaryBorderColor: '#16a34a',
      tertiaryColor: '#451a03',
      tertiaryTextColor: '#fcd34d',
      tertiaryBorderColor: '#d97706',
      background: '#0f172a',
      mainBkg: '#312e81',
      nodeBorder: '#818cf8',
      clusterBkg: '#1e293b',
      clusterBorder: '#334155',
      titleColor: '#f1f5f9',
      edgeLabelBackground: '#1e293b',
      fontFamily: 'Inter, system-ui, -apple-system, sans-serif',
      fontSize: '14px',
    };

    return {
      startOnLoad: false,
      theme: 'base' as const,
      themeVariables: isDark ? dark : light,
      securityLevel: 'loose' as const,
      flowchart: {
        useMaxWidth: true,
        htmlLabels: true,
        curve: 'basis',
        padding: 20,
      },
      sequence: { useMaxWidth: true, mirrorActors: false },
      er: { useMaxWidth: true },
      gantt: { useMaxWidth: true },
    };
  }

  /**
   * Make a rendered SVG string responsive:
   * - Replace fixed pixel width/height with 100%/auto
   * - Add max-width:100% so it never overflows its container
   */
  function makeResponsiveSvg(svg: string): string {
    // Strategy: remove fixed width/height attrs, keep viewBox, and set
    // CSS so the diagram never overflows but also never stretches beyond
    // its natural rendered size.
    //
    // We derive "natural width" from the viewBox (more reliable than the
    // width attr which mermaid sometimes sets to 100%) so the diagram
    // renders at an appropriate scale in its card.
    //
    // max-width is capped at 960px (typical content column) so huge
    // diagrams don't dominate the page, and min diagrams won't stretch.

    const vbMatch = svg.match(/\bviewBox="[^"]*"/);
    let naturalPx = 960; // sensible default cap
    if (vbMatch) {
      const parts = vbMatch[0].replace(/viewBox="|"/g, '').trim().split(/[\s,]+/);
      if (parts.length >= 4) {
        const vbW = parseFloat(parts[2]);
        if (!isNaN(vbW) && vbW > 0) naturalPx = Math.min(vbW, 960);
      }
    } else {
      const wMatch = svg.match(/\bwidth="(\d[\d.]*)/);
      if (wMatch) naturalPx = Math.min(parseFloat(wMatch[1]), 960);
    }

    return svg
      .replace(/\bwidth="[^"]*"/, '')
      .replace(/\bheight="[^"]*"/, '')
      .replace(/<svg /, `<svg style="display:block;margin:0 auto;width:100%;max-width:${naturalPx}px;height:auto;" `);
  }

  /* -----------------------------------------------------------------------
   * Build a zoom-enabled diagram card around a rendered SVG.
   * Controls are ALWAYS visible (not hover-dependent) so they're
   * discoverable on first view.
   * -------------------------------------------------------------------- */
  function buildDiagramCard(rawSvg: string, diagramIndex: number): HTMLElement {
    const uid = `md-${diagramIndex}-${Date.now()}`;
    // Mermaid SVG is generated by mermaid.js from our own markdown content —
    // it is NOT user input. Skip DOMPurify: sanitizing SVG with foreignObject
    // (used by mermaid htmlLabels:true) strips all HTML label text regardless
    // of allowlist configuration, leaving empty diagram nodes.
    const cleanSvg = makeResponsiveSvg(rawSvg);

    const MIN_ZOOM = 50, MAX_ZOOM = 400, STEP = 25;
    let zoom = 100;

    // --- outer card ---
    const card = document.createElement('div');
    card.className = 'mermaid-rendered-svg';
    card.style.cssText = [
      'position: relative',
      'width: 100%',
      'box-sizing: border-box',
      'background: var(--color-surface)',
      'border: 1px solid var(--color-surface-tertiary)',
      'border-radius: 12px',
      'margin: 20px 0',
      'overflow: hidden',
      'box-shadow: var(--shadow-card, 0 1px 3px rgba(0,0,0,.06))',
    ].join('; ');

    // --- viewport (clips overflow when zoomed) ---
    const viewport = document.createElement('div');
    viewport.style.cssText = [
      'overflow: hidden',
      'width: 100%',
      'box-sizing: border-box',
      'position: relative',
    ].join('; ');
    card.appendChild(viewport);

    // --- SVG stage (scaled + panned) ---
    const stage = document.createElement('div');
    stage.id = `${uid}-stage`;
    stage.style.cssText = [
      'padding: 24px 20px',
      'text-align: center',
      'transform-origin: top center',
      'transition: transform 200ms cubic-bezier(0.25,1,0.5,1)',
      'cursor: grab',
      'width: 100%',
      'box-sizing: border-box',
      'will-change: transform',
    ].join('; ');
    stage.innerHTML = cleanSvg;
    viewport.appendChild(stage);

    // --- zoom toolbar (always visible) ---
    const toolbar = document.createElement('div');
    toolbar.style.cssText = [
      'display: flex',
      'align-items: center',
      'justify-content: space-between',
      'padding: 6px 12px',
      'border-top: 1px solid var(--color-surface-tertiary)',
      'background: var(--color-surface-secondary)',
    ].join('; ');

    const btnStyle = [
      'display: inline-flex',
      'align-items: center',
      'justify-content: center',
      'width: 32px',
      'height: 32px',
      'border-radius: 6px',
      'border: none',
      'background: transparent',
      'color: var(--color-content-secondary)',
      'cursor: pointer',
      'transition: background 150ms ease, color 150ms ease',
      'font-size: 13px',
    ].join('; ');

    function makeBtn(label: string, svgPath: string): HTMLButtonElement {
      const b = document.createElement('button');
      b.setAttribute('aria-label', label);
      b.setAttribute('title', label);
      b.style.cssText = btnStyle;
      b.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">${svgPath}</svg>`;
      b.addEventListener('mouseenter', () => { b.style.background = 'var(--color-surface-tertiary)'; b.style.color = 'var(--color-content)'; });
      b.addEventListener('mouseleave', () => { b.style.background = 'transparent'; b.style.color = 'var(--color-content-secondary)'; });
      return b;
    }

    const zoomOutBtn = makeBtn('Zoom out',
      '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/>');
    const zoomInBtn = makeBtn('Zoom in',
      '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>');
    const resetBtn = makeBtn('Reset zoom',
      '<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>');
    const expandBtn = makeBtn('Full screen',
      '<path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>');
    expandBtn.style.color = 'var(--color-primary)';

    const label = document.createElement('span');
    label.style.cssText = [
      'min-width: 40px',
      'text-align: center',
      'font-size: 0.72rem',
      'font-weight: 600',
      'font-variant-numeric: tabular-nums',
      'color: var(--color-content-secondary)',
      'user-select: none',
    ].join('; ');
    label.textContent = '100%';

    // Pan state
    let panX = 0, panY = 0;

    function applyZoom() {
      const clamped = Math.max(MIN_ZOOM, Math.min(MAX_ZOOM, Math.round(zoom / STEP) * STEP));
      zoom = clamped;
      // Reset pan when back to 100%
      if (clamped === 100) { panX = 0; panY = 0; }
      stage.style.transform = `scale(${clamped / 100}) translate(${panX}px, ${panY}px)`;
      stage.style.transformOrigin = 'top center';
      stage.style.cursor = clamped > 100 ? 'grab' : 'zoom-in';
      label.textContent = `${clamped}%`;
      (zoomOutBtn as HTMLButtonElement).disabled = clamped <= MIN_ZOOM;
      (zoomInBtn as HTMLButtonElement).disabled  = clamped >= MAX_ZOOM;
    }

    // ── Drag-to-pan for inline card ──────────────────────────────────────
    let dragging = false;
    let dragStartX = 0, dragStartY = 0;
    let panStartX = 0, panStartY = 0;
    let didDrag = false; // distinguishes a drag from a click

    stage.addEventListener('mousedown', (e: MouseEvent) => {
      if (zoom <= 100) return; // no pan needed at 100%
      e.preventDefault();
      dragging = true;
      didDrag = false;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      panStartX = panX;
      panStartY = panY;
      stage.style.cursor = 'grabbing';
      stage.style.transition = 'none'; // instant while dragging
    });

    window.addEventListener('mousemove', (e: MouseEvent) => {
      if (!dragging) return;
      const dx = (e.clientX - dragStartX) / (zoom / 100);
      const dy = (e.clientY - dragStartY) / (zoom / 100);
      if (Math.abs(dx) > 2 || Math.abs(dy) > 2) didDrag = true;
      panX = panStartX + dx;
      panY = panStartY + dy;
      stage.style.transform = `scale(${zoom / 100}) translate(${panX}px, ${panY}px)`;
    });

    window.addEventListener('mouseup', () => {
      if (!dragging) return;
      dragging = false;
      stage.style.cursor = zoom > 100 ? 'grab' : 'zoom-in';
      stage.style.transition = 'transform 200ms cubic-bezier(0.25,1,0.5,1)';
    });

    // Touch drag-to-pan
    let touchStartX = 0, touchStartY = 0;
    let touchPanStartX = 0, touchPanStartY = 0;

    stage.addEventListener('touchstart', (e: TouchEvent) => {
      if (zoom <= 100 || e.touches.length !== 1) return;
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchPanStartX = panX;
      touchPanStartY = panY;
      stage.style.transition = 'none';
    }, { passive: true });

    stage.addEventListener('touchmove', (e: TouchEvent) => {
      if (zoom <= 100 || e.touches.length !== 1) return;
      e.preventDefault();
      const dx = (e.touches[0].clientX - touchStartX) / (zoom / 100);
      const dy = (e.touches[0].clientY - touchStartY) / (zoom / 100);
      panX = touchPanStartX + dx;
      panY = touchPanStartY + dy;
      stage.style.transform = `scale(${zoom / 100}) translate(${panX}px, ${panY}px)`;
    }, { passive: false });

    stage.addEventListener('touchend', () => {
      stage.style.transition = 'transform 200ms cubic-bezier(0.25,1,0.5,1)';
    });

    zoomOutBtn.addEventListener('click', () => { zoom -= STEP; applyZoom(); });
    zoomInBtn.addEventListener('click',  () => { zoom += STEP; applyZoom(); });
    resetBtn.addEventListener('click',   () => { zoom = 100;   applyZoom(); });

    // Full-screen modal — only open on click if we didn't just finish a drag
    expandBtn.addEventListener('click',  () => openFullscreenModal(rawSvg));
    stage.addEventListener('click', (e: MouseEvent) => {
      if (didDrag) { didDrag = false; return; }
      openFullscreenModal(rawSvg);
    });

    // Left cluster: zoom controls
    const leftCluster = document.createElement('div');
    leftCluster.style.cssText = 'display:flex;align-items:center;gap:2px;';
    leftCluster.append(zoomOutBtn, label, zoomInBtn, resetBtn);

    // Right cluster: expand
    const rightCluster = document.createElement('div');
    rightCluster.style.cssText = 'display:flex;align-items:center;';
    rightCluster.appendChild(expandBtn);

    toolbar.append(leftCluster, rightCluster);
    card.appendChild(toolbar);

    return card;
  }

  /* -----------------------------------------------------------------------
   * Full-screen modal
   * -------------------------------------------------------------------- */
  function openFullscreenModal(rawSvg: string) {
    // Use the raw SVG (already responsive from mermaid render)
    // Strip fixed width/height so the SVG fills the modal container
    const svgForModal = rawSvg
      .replace(/\bwidth="[^"]*"/, 'width="100%"')
      .replace(/\bheight="[^"]*"/, 'height="100%"')
      .replace(/<svg /, '<svg style="display:block;width:100%;height:100%;" ');

    const modal = document.createElement('div');
    modal.style.cssText = 'position:fixed;inset:0;z-index:9999;display:flex;flex-direction:column;background:rgba(8,12,24,0.95);backdrop-filter:blur(12px);';
    modal.setAttribute('role', 'dialog');
    modal.setAttribute('aria-modal', 'true');
    modal.setAttribute('aria-label', 'Diagram full screen view');

    let zoom = 100;
    const MIN_ZOOM = 30, MAX_ZOOM = 500, STEP = 10;
    const clamp = (v: number) => Math.max(MIN_ZOOM, Math.min(MAX_ZOOM, Math.round(v / STEP) * STEP));

    // Build modal DOM directly (avoid innerHTML for SVG to preserve foreignObject)
    // --- close button ---
    const closeBtn = document.createElement('button');
    closeBtn.setAttribute('aria-label', 'Close');
    closeBtn.style.cssText = 'position:absolute;top:16px;right:16px;width:44px;height:44px;border-radius:50%;border:1px solid rgba(255,255,255,0.2);background:rgba(255,255,255,0.08);color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:22px;z-index:10;transition:background 150ms;';
    closeBtn.textContent = '×';
    closeBtn.addEventListener('mouseenter', () => { closeBtn.style.background = 'rgba(255,255,255,0.20)'; });
    closeBtn.addEventListener('mouseleave', () => { closeBtn.style.background = 'rgba(255,255,255,0.08)'; });
    modal.appendChild(closeBtn);

    // --- scroll/pan area ---
    const scrollArea = document.createElement('div');
    scrollArea.style.cssText = 'flex:1;overflow:auto;display:flex;align-items:center;justify-content:center;padding:48px 32px 80px;';
    modal.appendChild(scrollArea);

    // --- stage (scaled) ---
    const stage = document.createElement('div');
    stage.style.cssText = 'transform-origin:center center;transition:transform 180ms cubic-bezier(0.25,1,0.5,1);display:flex;align-items:center;justify-content:center;min-width:300px;cursor:grab;user-select:none;';
    scrollArea.appendChild(stage);

    // --- SVG wrapper: set explicit min-width so 100% SVG has a parent to resolve against ---
    const svgWrap = document.createElement('div');
    // Start at viewport-minus-padding width so SVG fills the modal nicely
    const initW = Math.min(window.innerWidth - 80, 1100);
    svgWrap.style.cssText = `width:${initW}px;`;
    svgWrap.innerHTML = svgForModal;
    stage.appendChild(svgWrap);

    // --- toolbar ---
    const toolbar = document.createElement('div');
    toolbar.style.cssText = 'position:absolute;bottom:20px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:8px;padding:8px 18px;border-radius:999px;background:rgba(15,23,42,0.92);border:1px solid rgba(255,255,255,0.12);backdrop-filter:blur(12px);white-space:nowrap;';

    const mkBtn = (label: string, svg: string) => {
      const b = document.createElement('button');
      b.setAttribute('aria-label', label);
      b.style.cssText = 'width:36px;height:36px;border-radius:8px;border:none;background:transparent;color:rgba(255,255,255,0.75);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 150ms;flex-shrink:0;';
      b.innerHTML = svg;
      b.addEventListener('mouseenter', () => { b.style.background = 'rgba(255,255,255,0.12)'; });
      b.addEventListener('mouseleave', () => { b.style.background = 'transparent'; });
      return b;
    };

    const outBtn = mkBtn('Zoom out', '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>');
    const inBtn  = mkBtn('Zoom in',  '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>');
    const resetBtn2 = mkBtn('Reset zoom', '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>');

    const slider = document.createElement('input');
    slider.type = 'range';
    slider.min = String(MIN_ZOOM);
    slider.max = String(MAX_ZOOM);
    slider.step = String(STEP);
    slider.value = '100';
    slider.setAttribute('aria-label', 'Zoom level');
    slider.style.cssText = 'width:120px;accent-color:#818cf8;cursor:pointer;';

    const labelEl = document.createElement('span');
    labelEl.style.cssText = 'min-width:44px;text-align:center;font-size:0.73rem;font-weight:600;color:rgba(255,255,255,0.9);font-variant-numeric:tabular-nums;';
    labelEl.textContent = '100%';

    toolbar.append(outBtn, slider, labelEl, inBtn, resetBtn2);
    modal.appendChild(toolbar);

    document.body.style.overflow = 'hidden';
    document.body.appendChild(modal);
    fixLabelContrast(svgWrap);

    function applyModalZoom() {
      zoom = clamp(zoom);
      if (zoom === 100) { mPanX = 0; mPanY = 0; }
      stage.style.cursor = 'grab';
      applyModalTransform();
      labelEl.textContent = `${zoom}%`;
      slider.value = String(zoom);
    }

    // ── Drag-to-pan inside modal ──────────────────────────────────────────
    let mPanX = 0, mPanY = 0;
    let mDragging = false;
    let mDragStartX = 0, mDragStartY = 0;
    let mPanStartX = 0, mPanStartY = 0;
    let mDidDrag = false;

    function applyModalTransform() {
      stage.style.transform = `scale(${zoom / 100}) translate(${mPanX}px, ${mPanY}px)`;
    }

    scrollArea.addEventListener('mousedown', (e: MouseEvent) => {
      // Only drag on the stage/diagram itself, not empty scrollArea bg
      if (e.target === scrollArea) return;
      e.preventDefault();
      mDragging = true;
      mDidDrag = false;
      mDragStartX = e.clientX;
      mDragStartY = e.clientY;
      mPanStartX = mPanX;
      mPanStartY = mPanY;
      stage.style.cursor = 'grabbing';
      stage.style.transition = 'none';
    });

    window.addEventListener('mousemove', (e: MouseEvent) => {
      if (!mDragging) return;
      const scale = zoom / 100;
      const dx = (e.clientX - mDragStartX) / scale;
      const dy = (e.clientY - mDragStartY) / scale;
      if (Math.abs(dx) > 2 || Math.abs(dy) > 2) mDidDrag = true;
      mPanX = mPanStartX + dx;
      mPanY = mPanStartY + dy;
      applyModalTransform();
    });

    window.addEventListener('mouseup', () => {
      if (!mDragging) return;
      mDragging = false;
      stage.style.cursor = 'grab';
      stage.style.transition = 'transform 180ms cubic-bezier(0.25,1,0.5,1)';
    });

    // Touch drag for modal
    let mTouchStartX = 0, mTouchStartY = 0;
    let mTouchPanStartX = 0, mTouchPanStartY = 0;

    scrollArea.addEventListener('touchstart', (e: TouchEvent) => {
      if (e.touches.length !== 1) return;
      mTouchStartX = e.touches[0].clientX;
      mTouchStartY = e.touches[0].clientY;
      mTouchPanStartX = mPanX;
      mTouchPanStartY = mPanY;
      stage.style.transition = 'none';
    }, { passive: true });

    scrollArea.addEventListener('touchmove', (e: TouchEvent) => {
      if (e.touches.length !== 1) return;
      e.preventDefault();
      const scale = zoom / 100;
      const dx = (e.touches[0].clientX - mTouchStartX) / scale;
      const dy = (e.touches[0].clientY - mTouchStartY) / scale;
      mPanX = mTouchPanStartX + dx;
      mPanY = mTouchPanStartY + dy;
      applyModalTransform();
    }, { passive: false });

    scrollArea.addEventListener('touchend', () => {
      stage.style.transition = 'transform 180ms cubic-bezier(0.25,1,0.5,1)';
    });

    closeBtn.addEventListener('click', close);
    outBtn.addEventListener('click',    () => { zoom -= STEP; applyModalZoom(); });
    inBtn.addEventListener('click',     () => { zoom += STEP; applyModalZoom(); });
    resetBtn2.addEventListener('click', () => { zoom = 100; mPanX = 0; mPanY = 0; applyModalZoom(); });
    slider.addEventListener('input',    () => { zoom = Number(slider.value); applyModalZoom(); });
    modal.addEventListener('click', (e) => {
      if (mDidDrag) { mDidDrag = false; return; }
      if (e.target === modal || e.target === scrollArea) close();
    });
    modal.addEventListener('wheel', (e: WheelEvent) => {
      e.preventDefault();
      zoom += e.deltaY < 0 ? STEP : -STEP;
      applyModalZoom();
    }, { passive: false });

    function onKey(e: KeyboardEvent) {
      if (e.key === 'Escape')              { close(); }
      if (e.key === '+' || e.key === '=') { zoom += STEP; applyModalZoom(); }
      if (e.key === '-')                   { zoom -= STEP; applyModalZoom(); }
      if (e.key === '0')                   { zoom = 100;   applyModalZoom(); }
    }
    document.addEventListener('keydown', onKey);

    function close() {
      document.body.style.overflow = '';
      document.removeEventListener('keydown', onKey);
      modal.remove();
    }

    applyModalZoom();
  }

  /* -----------------------------------------------------------------------
   * remarkMermaid outputs this structure inside LayerCollapse content:
   *
   *   <div class="mermaid-diagram" data-mermaid-source="...">
   *     <div class="mermaid-render">
   *       <pre class="mermaid">ESCAPED_SOURCE</pre>   ← target this
   *     </div>
   *     <div class="mermaid-fallback" style="display:none;">…</div>
   *   </div>
   *
   * We target pre.mermaid — its textContent is the decoded mermaid source.
   * mermaid.render(id, source) without a container appends a temp element
   * to <body>, renders into it, returns the SVG string, and cleans up.
   * This is the approach that was confirmed working in the original code.
   * -------------------------------------------------------------------- */
  let renderCounter = 0;

  /**
   * Many content diagrams hard-code light pastel node fills
   * (e.g. "style IN fill:#e1f5fe"). Those fills override mermaid's theme,
   * so in dark mode the theme's light label text lands on a light box and
   * becomes unreadable. Fix: measure each node's actual fill luminance and
   * force a contrasting label color. Must run on an element attached to the
   * DOM (getComputedStyle needs it).
   */
  function fixLabelContrast(container: HTMLElement) {
    container.querySelectorAll<SVGGElement>('g.node, g.cluster').forEach((node) => {
      const shape = node.querySelector<SVGElement>('rect, polygon, circle, ellipse, path');
      if (!shape) return;
      const fill = getComputedStyle(shape).fill;
      const m = fill.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/);
      if (!m) return;
      if (m[4] !== undefined && parseFloat(m[4]) < 0.5) return; // mostly transparent — page bg shows through
      const lum = 0.2126 * +m[1] + 0.7152 * +m[2] + 0.0722 * +m[3];
      const color = lum > 140 ? '#1e293b' : '#f1f5f9';
      node.querySelectorAll<HTMLElement>('.nodeLabel, span, div, p').forEach((el) => {
        el.style.setProperty('color', color, 'important');
      });
      node.querySelectorAll<SVGElement>('text, tspan').forEach((el) => {
        el.style.setProperty('fill', color, 'important');
      });
    });
  }

  async function renderOnePre(pre: HTMLElement) {
    if (pre.dataset.rendered === 'true') return;

    const source = pre.textContent?.trim() ?? '';
    if (!source) return;

    // Guard immediately — MutationObserver can fire multiple times
    pre.dataset.rendered = 'true';
    const idx = renderCounter++;
    const id  = `mermaid-diagram-${idx}`;

    try {
      // mermaid.render(id, text) — no container arg:
      //  • appends a hidden temp div to <body> for D3 layout
      //  • resolves with { svg: string }
      //  • cleans up the temp div itself
      const mermaid = await loadMermaid();
      const { svg } = await mermaid.render(id, source);

      if (!svg) throw new Error('empty SVG');

      // Mermaid sometimes resolves with an error SVG instead of throwing.
      // The error SVG contains class="error-text" on its text nodes (confirmed
      // from mermaid v11 source). Do NOT check for "mermaid version" — that
      // string appears in ALL mermaid SVGs, not just error ones.
      if (svg.includes('class="error-text"') || svg.includes("class='error-text'")) {
        throw new Error('mermaid returned error SVG');
      }

      const card = buildDiagramCard(svg, idx);
      // Keep the source on the card so the diagram can be re-rendered with
      // the matching mermaid theme when the user switches light/dark mode.
      card.dataset.mermaidSource = source;

      // Replace the closest .mermaid-render parent if present, else the pre
      const target = pre.closest<HTMLElement>('.mermaid-render') ?? pre;
      target.replaceWith(card);
      fixLabelContrast(card);
    } catch (err) {
      pre.dataset.rendered = 'error';
      // Style the pre as a readable code block fallback
      pre.style.cssText = [
        'display: block',
        'background: var(--color-surface-secondary)',
        'color: var(--color-content)',
        'border: 1px dashed var(--color-warning, #f59e0b)',
        'border-radius: 8px',
        'padding: 16px',
        'white-space: pre-wrap',
        'font-size: 0.82rem',
        'font-family: "JetBrains Mono", monospace',
        'width: 100%',
        'box-sizing: border-box',
        'margin: 0',
      ].join('; ');
    }
  }

  async function renderAllDiagrams() {
    const pres = document.querySelectorAll<HTMLElement>('pre.mermaid');
    if (pres.length === 0) return; // no diagrams — never fetch mermaid
    const mermaid = await loadMermaid();
    mermaid.initialize(getMermaidConfig());
    for (const pre of Array.from(pres)) {
      await renderOnePre(pre);
    }
  }

  /* -----------------------------------------------------------------------
   * Theme switching — re-render every diagram in place with the new theme's
   * mermaid config. The source survives on card.dataset.mermaidSource; the
   * new SVG is swapped into the existing card's stage so zoom controls and
   * layout are preserved.
   * -------------------------------------------------------------------- */
  let themeRerenderToken = 0;

  async function rerenderDiagramsForTheme() {
    const cards = document.querySelectorAll<HTMLElement>('.mermaid-rendered-svg[data-mermaid-source]');
    if (cards.length === 0) return;

    const token = ++themeRerenderToken;
    const mermaid = await loadMermaid();
    mermaid.initialize(getMermaidConfig());

    for (const card of Array.from(cards)) {
      // A newer theme switch superseded this pass — abandon it
      if (token !== themeRerenderToken) return;

      const source = card.dataset.mermaidSource!;
      try {
        const { svg } = await mermaid.render(`mermaid-retheme-${renderCounter++}`, source);
        if (!svg || svg.includes('class="error-text"') || svg.includes("class='error-text'")) continue;
        const stage = card.querySelector<HTMLElement>('[id$="-stage"]');
        if (stage) {
          stage.innerHTML = makeResponsiveSvg(svg);
          fixLabelContrast(stage);
        }
      } catch {
        // Keep the previous SVG rather than blanking the diagram
      }
    }
  }

  // Watch <html> class for light/dark flips. Track previous state so other
  // class churn (e.g. the transient "theme-transition" class) doesn't
  // trigger spurious re-renders.
  let wasDark = document.documentElement.classList.contains('dark');
  const themeObserver = new MutationObserver(() => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark !== wasDark) {
      wasDark = isDark;
      rerenderDiagramsForTheme();
    }
  });
  themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  // -----------------------------------------------------------------------
  // MutationObserver — catches pre.mermaid elements added by LayerCollapse
  // React hydration (which happens asynchronously after the script runs)
  // -----------------------------------------------------------------------
  const diagramObserver = new MutationObserver((mutations) => {
    for (const m of mutations) {
      for (const node of Array.from(m.addedNodes)) {
        if (!(node instanceof HTMLElement)) continue;
        // Node itself might be pre.mermaid
        if (node.matches('pre.mermaid')) {
          renderOnePre(node);
        }
        // Or pre.mermaid elements nested inside an added subtree
        node.querySelectorAll<HTMLElement>('pre.mermaid').forEach(renderOnePre);
      }
    }
  });

  diagramObserver.observe(document.body, { childList: true, subtree: true });

  // Initial pass for anything already in the DOM
  renderAllDiagrams();

  // Re-run on Astro page transitions
  document.addEventListener('astro:page-load', () => {
    renderCounter = 0;
    renderAllDiagrams();
  });

  // Re-render on theme change
  const htmlObserver = new MutationObserver((mutations) => {
    for (const m of mutations) {
      if (m.attributeName === 'class') {
        resetThemeAndRerender();
        break;
      }
    }
  });
  htmlObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>

<script>
  /**
   * Client-side difficulty filter logic.
   * Filters scenario question elements based on selected difficulty level.
   * Requirements: 3.4
   */
  (function() {
    const filterContainer = document.querySelector('[data-testid="difficulty-filter"]');
    if (!filterContainer) return;

    const checkboxes = filterContainer.querySelectorAll<HTMLInputElement>('input[name="difficulty"]');
    const scenariosContainer = document.querySelector('[data-testid="scenarios-content"]');
    if (!scenariosContainer) return;

    // Get all scenario question articles (elements with data-difficulty attribute)
    function getScenarioElements(): HTMLElement[] {
      return Array.from(scenariosContainer!.querySelectorAll('[data-difficulty]'));
    }

    function applyFilter() {
      const selected = Array.from(checkboxes)
        .filter((cb) => cb.checked)
        .map((cb) => cb.value);

      // If "all" is checked or nothing is checked, show everything
      const showAll = selected.includes('all') || selected.length === 0;

      const scenarios = getScenarioElements();
      scenarios.forEach((el) => {
        const difficulty = el.getAttribute('data-difficulty');
        if (showAll || (difficulty && selected.includes(difficulty))) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    }

    // Handle mutual exclusivity: "all" vs specific filters
    checkboxes.forEach((cb) => {
      cb.addEventListener('change', () => {
        if (cb.value === 'all' && cb.checked) {
          // Uncheck specific filters when "all" is selected
          checkboxes.forEach((other) => {
            if (other.value !== 'all') other.checked = false;
          });
        } else if (cb.value !== 'all' && cb.checked) {
          // Uncheck "all" when a specific filter is selected
          const allCb = filterContainer!.querySelector<HTMLInputElement>('[data-filter="all"]');
          if (allCb) allCb.checked = false;
        }

        // If no specific filters are checked, re-check "all"
        const specificChecked = Array.from(checkboxes).some(
          (c) => c.value !== 'all' && c.checked
        );
        if (!specificChecked) {
          const allCb = filterContainer!.querySelector<HTMLInputElement>('[data-filter="all"]');
          if (allCb) allCb.checked = true;
        }

        applyFilter();
      });
    });

    // Initial filter application
    applyFilter();
  })();
</script>
